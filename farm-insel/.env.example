# ChirpStack Datenbank
CHIRPSTACK_DB_USER=chirpstack
CHIRPSTACK_DB_PASS=sicher_aendern_123

# ChirpStack API-Secret (mind. 32 Zeichen, zufällig)
# Generieren: openssl rand -hex 32
CHIRPSTACK_API_SECRET=bitte_aendern_mit_openssl_rand_hex_32

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASS=sicher_aendern_456

# ERPNext / MariaDB
MARIADB_ROOT_PASS=sicher_aendern_789
