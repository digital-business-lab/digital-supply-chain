# =============================================================
# SCM Lab — .gitignore
# =============================================================

# ── Passwords & Secrets (NEVER commit!) ──────────────────────
.env
*.secret
**/env.secret

# ── Backups ──────────────────────────────────────────────────
farm-backups/
factory-backups/
distributor-backups/
*.tar.gz
*.sql.gz

# ── Docker runtime data ───────────────────────────────────────
**/volumes/
**/data/

# ── Operating system ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Node / npm ────────────────────────────────────────────────
node_modules/
npm-debug.log

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/

# ── Temporary files ───────────────────────────────────────────
*.tmp
*.log

# ── MkDocs build output ──────────────────────────────────────────────────────
site/
