# ============================================================
# Farm Island — Environment Variables
# Copy file: cp .env.example .env
# Then fill in all passwords with secure values!
# ============================================================

# ChirpStack database
CHIRPSTACK_DB_USER=chirpstack
CHIRPSTACK_DB_PASS=change_me_securely_123

# ChirpStack API secret (min. 32 characters, random)
# Generate: openssl rand -hex 32
CHIRPSTACK_API_SECRET=change_me_with_openssl_rand_hex_32

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASS=change_me_securely_456

# ERPNext / MariaDB
MARIADB_ROOT_PASS=change_me_securely_789
